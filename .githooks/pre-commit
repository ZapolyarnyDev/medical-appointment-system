#!/usr/bin/env sh
set -eu

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

if [ -n "$staged_files" ]; then
    if [ "${OS:-}" = "Windows_NT" ]; then
        ./gradlew.bat spotlessApply
    else
        ./gradlew spotlessApply
    fi

    printf '%s\n' "$staged_files" | while IFS= read -r file; do
        if [ -e "$file" ]; then
            git add -- "$file"
        fi
    done
fi
